# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Database connection (if using @mastra/pg)
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Optional: OpenAI API key for semantic recall embeddings
# OPENAI_API_KEY=sk-...

# Optional: NCBI API key — increases PubMed/ClinVar rate limit from 3 to 10 req/sec
# Register at https://www.ncbi.nlm.nih.gov/account/
# NCBI_API_KEY=...

# Optional: OMIM API key — enables gene-disease relationship lookup in deep research
# Register at https://omim.org/api (free for academic use)
# OMIM_API_KEY=...

# Optional: OpenFDA API key — increases FDA adverse event rate limit (240/min without, higher with)
# Register at https://open.fda.gov/apis/authentication/
# OPENFDA_API_KEY=...

# Optional: Isabel DDx API key — enables professional differential diagnosis engine
# Requires institutional subscription at https://www.isabelhealthcare.com/
# ISABELDX_API_KEY=...

# Optional: Override dynamic maxSteps resolution (default: 5-20 based on query complexity)
# ASKLEPIOS_MAX_STEPS=15

# Optional: Log level (debug | info | warn | error)
LOG_LEVEL=info

# Optional: Node environment
NODE_ENV=development
