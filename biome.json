{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 15 }
        },
        "noVoid": "error",
        "useSimplifiedLogicExpression": "warn",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "error",
        "useExhaustiveDependencies": "warn",
        "noUndeclaredVariables": "error"
      },
      "style": {
        "noDefaultExport": "error",
        "useConst": "error",
        "useExportType": "error",
        "useImportType": "error",
        "noNonNullAssertion": "warn",
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "conventions": [
              { "selector": { "kind": "function" }, "formats": ["camelCase"] },
              {
                "selector": { "kind": "variable" },
                "formats": ["camelCase", "CONSTANT_CASE", "PascalCase"]
              },
              { "selector": { "kind": "typeLike" }, "formats": ["PascalCase"] },
              { "selector": { "kind": "enum" }, "formats": ["PascalCase"] },
              {
                "selector": { "kind": "objectLiteralProperty" },
                "formats": ["camelCase", "snake_case"]
              },
              {
                "selector": { "kind": "typeProperty" },
                "formats": ["camelCase", "snake_case"]
              }
            ]
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": "warn",
        "noDebugger": "error",
        "noDoubleEquals": "error",
        "noImplicitAnyLet": "error",
        "noConfusingVoidType": "error"
      },
      "performance": {
        "noBarrelFile": "off",
        "noReExportAll": "warn"
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noMisusedPromises": "error",
        "useExplicitType": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "files": {
    "includes": ["src/**/*.ts", "tests/**/*.ts"],
    "experimentalScannerIgnores": ["node_modules", "dist", "coverage", ".mastra"]
  },
  "overrides": [
    {
      "includes": ["src/**/*.test.ts", "tests/**/*.ts"],
      "javascript": {
        "globals": ["jest"]
      },
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": {
              "level": "warn",
              "options": {
                "conventions": [
                  { "selector": { "kind": "function" }, "formats": ["camelCase"] },
                  {
                    "selector": { "kind": "variable" },
                    "formats": ["camelCase", "CONSTANT_CASE", "PascalCase"]
                  },
                  { "selector": { "kind": "typeLike" }, "formats": ["PascalCase"] },
                  { "selector": { "kind": "enum" }, "formats": ["PascalCase"] },
                  {
                    "selector": { "kind": "objectLiteralProperty" },
                    "formats": ["camelCase", "snake_case", "PascalCase", "CONSTANT_CASE"]
                  },
                  {
                    "selector": { "kind": "typeProperty" },
                    "formats": ["camelCase", "snake_case"]
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
